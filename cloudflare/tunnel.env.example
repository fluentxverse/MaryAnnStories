#
# Copy the values you need into your real `.env` before starting docker-compose.
# This file is just a deployment reference.
#

# Cloudflare Zero Trust tunnel token for the connector container.
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Public frontend origin that is allowed by the backend CORS layer.
# For production with a Worker frontend, this should be the Worker/custom-domain origin.
APP_FRONTEND_ORIGIN=https://maryannstories.yourdomain.com

# Public image host used in saved story/image URLs.
# Point this at a public hostname that reaches the Seaweed filer.
SEAWEED_PUBLIC_URL=https://images.yourdomain.com
